  <diagram name="第 1 页" id="oF-aEi5Qlhgarhgo01UW">
    <mxGraphModel dx="2056" dy="2006" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=24;fontStyle=1" value="MobileViT 研究報告邏輯流程圖" vertex="1">
          <mxGeometry height="40" width="560" x="520" y="20" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16" value="研究背景&#xa;Hybrid CNN-Transformer 模型興起&#xa;• CNN：擅長 local feature&#xa;• Transformer：擅長 global dependency" vertex="1">
          <mxGeometry height="120" width="280" x="80" y="100" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16" value="核心問題定義&#xa;Hybrid 模型存在跨域資料表示&#xa;• Feature map：(B,C,H,W)&#xa;• Token sequence：(B,N,C)&#xa;• Attention score：(B,head,N,N)" vertex="1">
          <mxGeometry height="140" width="330" x="430" y="100" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16" value="實際挑戰&#xa;1. 排程僵化與管線停滯&#xa;2. 資料格式轉換開銷高&#xa;3. Memory movement / EMA 過大&#xa;4. Hardware utilization 降低" vertex="1">
          <mxGeometry height="140" width="320" x="840" y="100" as="geometry" />
        </mxCell>
        <mxCell id="e1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16" value="文獻證據&#xa;• Transformer accelerator：EMA 可占大部分能耗&#xa;• Utilization 常遠低於 peak&#xa;⇒ 問題不只在 compute" vertex="1">
          <mxGeometry height="120" width="300" x="120" y="320" as="geometry" />
        </mxCell>
        <mxCell id="e2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16" value="模型結構證據&#xa;MobileViT block：&#xa;Feature map → unfold → token → attention → fold → feature map&#xa;⇒ Feature / Token 轉換頻繁" vertex="1">
          <mxGeometry height="140" width="330" x="470" y="320" as="geometry" />
        </mxCell>
        <mxCell id="e3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16" value="Profiling 證據&#xa;Layer-wise MACs / activation 分析&#xa;• 高 MACs layer 不平均&#xa;• 熱點集中在 Conv、Projection、Attention 交界&#xa;⇒ 計算與資料搬移共同形成瓶頸" vertex="1">
          <mxGeometry height="150" width="350" x="850" y="320" as="geometry" />
        </mxCell>
        <mxCell id="j1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=16" value="研究空白&#xa;現有方法多統一 compute engine&#xa;但尚未真正統一&#xa;layer-to-layer tensor layout / dataflow" vertex="1">
          <mxGeometry height="130" width="300" x="360" y="540" as="geometry" />
        </mxCell>
        <mxCell id="j2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" value="研究方法&#xa;Layer Fusion + Tensor-Layout-Aware Dataflow&#xa;• Conv → Tokenization → QKV 串接&#xa;• QKV → Attention → Projection 串接&#xa;• Transformer output → Fold → Conv 串接" vertex="1">
          <mxGeometry height="160" width="430" x="730" y="530" as="geometry" />
        </mxCell>
        <mxCell id="goal" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" value="預期目標&#xa;• 降低 DRAM round-trip / EMA&#xa;• 降低 feature-token 轉換成本&#xa;• 提升 PE utilization&#xa;• 改善整體 latency / energy efficiency" vertex="1">
          <mxGeometry height="140" width="360" x="470" y="760" as="geometry" />
        </mxCell>
        <mxCell id="n1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1" value="一句話總結&#xa;問題：資料格式轉換與 memory movement&#xa;證據：文獻 + 結構 + profiling&#xa;方法：Layer Fusion / Unified Dataflow" vertex="1">
          <mxGeometry height="140" width="330" x="920" y="760" as="geometry" />
        </mxCell>
