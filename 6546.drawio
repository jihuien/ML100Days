  <diagram name="第 1 页" id="SEV1D9PUt8mIj-L9HbmI">
    <mxGraphModel dx="2056" dy="1106" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=26;fontStyle=1" value="ISSCC ConvFormer Accelerator 論文邏輯架構圖" vertex="1">
          <mxGeometry height="40" width="760" x="520" y="20" as="geometry" />
        </mxCell>
        <mxCell id="p1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16" value="應用場景&#xa;Semantic Segmentation&#xa;• 高解析度輸入&#xa;• 長 token length (&gt;16K)" vertex="1">
          <mxGeometry height="120" width="250" x="70" y="110" as="geometry" />
        </mxCell>
        <mxCell id="p2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16" value="Backbone Bottleneck&#xa;Memory-Intensive&#xa;• Attention feature map 很大&#xa;• EMA / buffer 壓力高" vertex="1">
          <mxGeometry height="120" width="280" x="390" y="110" as="geometry" />
        </mxCell>
        <mxCell id="p3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16" value="Segmentation Head Bottleneck&#xa;Compute-Intensive&#xa;• 低 sparsity&#xa;• 傳統 zero-skipping 效益有限" vertex="1">
          <mxGeometry height="120" width="300" x="740" y="110" as="geometry" />
        </mxCell>
        <mxCell id="p4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=16;fontStyle=1" value="核心問題定義&#xa;Memory-Compute-Intensity Mismatch&#xa;• EMA 過大&#xa;• Layer fusion 受限&#xa;• 系統效率不佳" vertex="1">
          <mxGeometry height="120" width="310" x="1110" y="110" as="geometry" />
        </mxCell>
        <mxCell id="m1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" value="Method 1: HAPU&#xa;Hybrid-Attention Processing Unit&#xa;• 結合 Linear Attention + Vanilla Attention&#xa;• 只保留少量 VA tiles 維持準確度&#xa;• 將 QK^T-first 改為 K^TV-first" vertex="1">
          <mxGeometry height="170" width="360" x="90" y="320" as="geometry" />
        </mxCell>
        <mxCell id="m2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" value="Method 2: DR-LFS&#xa;Data-Reuse Layer-Fusion Scheduler&#xa;• Tile grouping&#xa;• 將 VA tiles 集中處理&#xa;• 重用 K/V 與 Conv weights&#xa;• 減少 feature-map EMA / weight EMA" vertex="1">
          <mxGeometry height="170" width="360" x="520" y="320" as="geometry" />
        </mxCell>
        <mxCell id="m3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" value="Method 3: CFMP&#xa;Cascaded Feature-Map Pruner&#xa;• 針對 segmentation head 低 sparsity&#xa;• 增加 feature-map sparsity&#xa;• 降低 compute 與 latency" vertex="1">
          <mxGeometry height="170" width="310" x="950" y="320" as="geometry" />
        </mxCell>
        <mxCell id="m4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=16;fontStyle=1" value="方法總結&#xa;Backbone：減少 EMA&#xa;Head：提升 sparsity&#xa;System：同時優化 memory 與 compute efficiency" vertex="1">
          <mxGeometry height="150" width="260" x="570" y="590" as="geometry" />
        </mxCell>
        <mxCell id="a1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=20;fontStyle=1" value="整體架構&#xa;ConvFormer Accelerator" vertex="1">
          <mxGeometry height="30" width="340" x="70" y="760" as="geometry" />
        </mxCell>
        <mxCell id="a2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15" value="Global Buffer (GB)&#xa;• 2MB LMB + 1MB RMB&#xa;• 保存 feature maps / KV / weights&#xa;• 支援 on-chip reuse" vertex="1">
          <mxGeometry height="140" width="260" x="570" y="810" as="geometry" />
        </mxCell>
        <mxCell id="a3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15" value="HAPU&#xa;• 處理 backbone attention&#xa;• Hybrid attention&#xa;• K^TV on-chip buffering" vertex="1">
          <mxGeometry height="120" width="220" x="380" y="1090" as="geometry" />
        </mxCell>
        <mxCell id="a4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15" value="Layer-Fusion Scheduler&#xa;• attention / conv tile scheduling&#xa;• Tile grouping&#xa;• 減少 K/V 與 weight reload" vertex="1">
          <mxGeometry height="140" width="260" x="660" y="1080" as="geometry" />
        </mxCell>
        <mxCell id="a5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15" value="Compute Core&#xa;• Convolution / Attention MAC engine&#xa;• 支援 backbone 與 segmentation head" vertex="1">
          <mxGeometry height="120" width="240" x="980" y="1090" as="geometry" />
        </mxCell>
        <mxCell id="a6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15" value="CFMP / Sparse Processing Path&#xa;• segmentation head feature-map pruning&#xa;• 增加有效 sparsity" vertex="1">
          <mxGeometry height="120" width="260" x="1280" y="1090" as="geometry" />
        </mxCell>
        <mxCell id="r1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" value="結果 1：Backbone EMA Reduction&#xa;• HAPU：減少 60.2% ~ 78.6% feature-map EMA&#xa;• HAPU + DR-LFS：最高 25.9× EMA reduction" vertex="1">
          <mxGeometry height="140" width="360" x="120" y="1310" as="geometry" />
        </mxCell>
        <mxCell id="r2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" value="結果 2：Latency / Energy 改善&#xa;• 4.66× ~ 7.11× speedup&#xa;• 4.39× ~ 7.10× energy savings" vertex="1">
          <mxGeometry height="140" width="330" x="570" y="1310" as="geometry" />
        </mxCell>
        <mxCell id="r3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16" value="結果 3：Segmentation Head Sparsity&#xa;• CFMP 將 sparsity 提升約 6×&#xa;• Latency reduction 約 49%" vertex="1">
          <mxGeometry height="140" width="330" x="980" y="1310" as="geometry" />
        </mxCell>
        <mxCell id="r4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1" value="論文核心結論&#xa;不是單純做更大的 compute engine&#xa;而是透過 HAPU + DR-LFS + CFMP&#xa;共同解決 memory-compute-intensity mismatch" vertex="1">
          <mxGeometry height="160" width="320" x="580" y="1650" as="geometry" />
        </mxCell>
